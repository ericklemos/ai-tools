{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "memory": {
      "type": "local",
      "enabled": true,
      "command": [
        "sh",
        "-lc",
        "MEMORY_FILE_PATH=\"$(git rev-parse --show-toplevel)/.opencode/memory.jsonl\" npx -y @modelcontextprotocol/server-memory"
      ]
    }
  },
  "agent": {
    "plan": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "build": {
      "model": "openai/gpt-5.3-codex"
    }
  }
}
